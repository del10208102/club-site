# 会话签名（生产环境务必改为随机长字符串）
SESSION_SECRET=请改为足够长的随机字符串

# 管理员账号（默认 admin）
ADMIN_USERNAME=admin

# 密码（二选一）
# 推荐：明文便于首次部署测试（上线后请改为哈希）
ADMIN_PASSWORD=fantasy2026

# 或生产环境使用 bcrypt 哈希（与 ADMIN_PASSWORD 二选一，哈希优先）
# npm run hash-password -- 你的密码
# ADMIN_PASSWORD_HASH=

# 开发环境若未配置任何密码，可使用 admin / fantasy2026 登录（仅 NODE_ENV!=production）

# Cookie Secure（可选）。默认根据请求头 X-Forwarded-Proto / URL 判断。
# 反代未传 X-Forwarded-Proto 时若仍无法登录，可设 COOKIE_SECURE=0 后重启。
# COOKIE_SECURE=0

# Nginx 反代时建议在进程环境（非必须写进本文件）中设置：
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host

NODE_ENV=development

# 数据与上传目录（相对路径时相对于「项目根」；项目根见下方 PROJECT_ROOT）
# DATA_DIR=data
# UPLOAD_DIR=uploads

# 可选：若进程工作目录不是项目根（部分 pm2 配置），必须指定，否则 data/uploads 会写到错误路径
# PROJECT_ROOT=/opt/club-site
